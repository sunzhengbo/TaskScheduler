<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:dialogs="clr-namespace:TaskScheduler.App.Dialogs"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="750"
             x:Class="TaskScheduler.App.Dialogs.CreateTaskDialog"
             x:DataType="dialogs:CreateTaskDialogViewModel"
             MaxWidth="900"
             MaxHeight="800">
    <ScrollViewer>
        <StackPanel Margin="20" Width="850">
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                <TextBlock Grid.Column="0" Text="基本信息" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding ImportFromFileCommand}" Padding="10,4" Classes="Flat">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <avalonia:MaterialIcon Kind="FileImport" Width="16" Height="16" />
                            <TextBlock Text="导入文件" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ImportFromClipboardCommand}" Padding="10,4" Classes="Flat">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <avalonia:MaterialIcon Kind="ClipboardText" Width="16" Height="16" />
                            <TextBlock Text="从剪贴板导入" FontSize="12" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,20" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto,*">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="任务名称:" VerticalAlignment="Center" Margin="0,5" Width="80" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Margin="5,5" />

                <TextBlock Grid.Row="0" Grid.Column="2" Text="任务分组:" VerticalAlignment="Center" Margin="0,5" Width="80" />
                <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding AvailableGroups}"
                          SelectedItem="{Binding Group}" Margin="5,5" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="任务描述:" VerticalAlignment="Center" Margin="0,5" Width="80" />
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Description}" Margin="5,5" />
            </Grid>

            <TextBlock Text="定时设置" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />

            <Grid Margin="0,0,0,20" RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto,*">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="触发类型:" VerticalAlignment="Center" Margin="0,5" Width="80" />
                <ComboBox Grid.Row="0" Grid.Column="1" SelectedItem="{Binding TriggerType}"
                          ItemsSource="{Binding AvailableTriggerTypes}" Margin="5,5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding }" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="重复次数:" VerticalAlignment="Center" Margin="0,5" Width="80" />
                <NumericUpDown Grid.Row="0" Grid.Column="3" Value="{Binding RepeatCount}" Minimum="0" Maximum="9999"
                               Margin="5,5" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="执行间隔:" VerticalAlignment="Center" Margin="0,5" Width="80" />
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="5,5">
                    <NumericUpDown Value="{Binding RepeatIntervalMinutes}" Minimum="1" Maximum="1440" Width="80"
                                   Margin="0,0,5,0" />
                    <TextBlock Text="分钟" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Cron表达式:" VerticalAlignment="Center" Margin="0,5"
                           Width="80" />
                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding CronExpression}" Margin="5,5" />
            </Grid>

            <TextBlock Text="命令配置" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />

            <Grid Margin="0,0,0,10" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="命令名称:" VerticalAlignment="Center" Margin="0,5" Width="80" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Command.Name}" Margin="5,5" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="命令类型:" VerticalAlignment="Center" Margin="0,5" Width="80" />
                <ComboBox Grid.Row="1" Grid.Column="1" SelectedItem="{Binding Command.Type}"
                          ItemsSource="{Binding AvailableCommandTypes}" Margin="5,5" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="命令描述:" VerticalAlignment="Center" Margin="0,5" Width="80" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Command.Description}" Margin="5,5" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="命令内容:" VerticalAlignment="Top" Margin="0,10" Width="80" />
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Command.Content}" Margin="5,5"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                         FontFamily="Consolas,Courier New,monospace" />
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10" Spacing="10">
                <Button Command="{Binding ExecuteCommandCommand}" Padding="15,8">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <avalonia:MaterialIcon Kind="Play" />
                        <TextBlock Text="测试执行" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <TextBlock Text="命令输出" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />
            <TextBox Text="{Binding CommandOutput}"
                     IsReadOnly="True"
                     Height="80"
                     Margin="0,0,0,10"
                     TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Command="{Binding CreateTaskCommand}" Padding="20,10">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <avalonia:MaterialIcon Kind="Check" />
                        <TextBlock Text="创建任务" FontWeight="Bold" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
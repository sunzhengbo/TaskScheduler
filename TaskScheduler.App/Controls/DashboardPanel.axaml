<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:TaskScheduler.App.Controls"
             x:Class="TaskScheduler.App.Controls.DashboardPanel">
    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1"
            BoxShadow="0 2 8 #08000000"
            ClipToBounds="True">
        <DockPanel>
            <!-- 面板头部 -->
            <Border DockPanel.Dock="Top" Padding="20,14"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="0,0,0,1">
                <TextBlock Text="{Binding Header, RelativeSource={RelativeSource AncestorType=local:DashboardPanel}}"
                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
            </Border>
            <!-- 内容区域 -->
            <ContentPresenter Content="{Binding PanelContent, RelativeSource={RelativeSource AncestorType=local:DashboardPanel}}" />
        </DockPanel>
    </Border>
</UserControl>

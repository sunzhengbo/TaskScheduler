<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:TaskScheduler.App.Controls"
             x:Class="TaskScheduler.App.Controls.CommandBlock">
    <StackPanel Spacing="1" Margin="0,0">
        <!-- Body -->
        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                CornerRadius="8" Padding="6,4"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1">
            <TextBlock Text="{Binding CommandBody, RelativeSource={RelativeSource AncestorType=local:CommandBlock}}"
                       FontFamily="Consolas,Courier New,monospace" FontSize="12"
                       TextWrapping="Wrap" />
        </Border>
        <!-- CommandType badge at bottom-right, outside the code block -->
        <Border CornerRadius="4" Padding="6,2"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                HorizontalAlignment="Right">
            <TextBlock Text="{Binding CommandType, RelativeSource={RelativeSource AncestorType=local:CommandBlock}}"
                       FontFamily="Consolas,Courier New,monospace" FontSize="10" />
        </Border>
    </StackPanel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:TaskScheduler.App.Controls"
             x:Class="TaskScheduler.App.Controls.StatCard">
    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            CornerRadius="12" Padding="20" Margin="4"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1">
        <StackPanel Spacing="4">
            <TextBlock x:Name="LabelBlock" Text="{Binding Label, RelativeSource={RelativeSource AncestorType=local:StatCard}}"
                       FontSize="13" />
            <TextBlock x:Name="ValueBlock" Text="{Binding Value, RelativeSource={RelativeSource AncestorType=local:StatCard}}"
                       FontSize="32" FontWeight="Bold" />
            <TextBlock x:Name="SubBlock" Text="{Binding Sub, RelativeSource={RelativeSource AncestorType=local:StatCard}}"
                       FontSize="12"
                       IsVisible="{Binding Sub, RelativeSource={RelativeSource AncestorType=local:StatCard}, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>
    </Border>
</UserControl>

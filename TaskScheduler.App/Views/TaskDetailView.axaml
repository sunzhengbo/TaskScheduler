<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:TaskScheduler.App.ViewModels"
             xmlns:controls="using:TaskScheduler.App.Controls"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:converters="using:TaskScheduler.App.Converters"
             xmlns:models="using:TaskScheduler.Core.Models"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="TaskScheduler.App.Views.TaskDetailView"
             x:DataType="vm:TaskDetailViewModel">

    <UserControl.Resources>
        <converters:TriggerStateToBadgeStatusConverter x:Key="TriggerStateToBadgeStatus" />
        <converters:TriggerStateToDisplayConverter x:Key="TriggerStateToDisplay" />
        <converters:ExecutionStatusToBadgeStatusConverter x:Key="ExecutionStatusToBadgeStatus" />
        <converters:ExecutionStatusToDisplayConverter x:Key="ExecutionStatusToDisplay" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*,*">
        <!-- Region 1: Toolbar -->
        <Border Grid.Row="0" Padding="24,12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button Command="{Binding GoBackCommand}" Classes="Flat" Padding="8" CornerRadius="8">
                        <avalonia:MaterialIcon Kind="ArrowLeft" Width="18" Height="18" />
                    </Button>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="{Binding CurrentTask.Name}" FontSize="18" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <controls:StatusBadge
                                Text="{Binding CurrentTask.FirstTrigger.State, Converter={StaticResource TriggerStateToDisplay}}"
                                Status="{Binding CurrentTask.FirstTrigger.State, Converter={StaticResource TriggerStateToBadgeStatus}}" />
                        </StackPanel>
                        <TextBlock Text="{Binding CurrentTask.Description}"
                                   FontSize="13" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis" MaxWidth="500" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Command="{Binding ExecuteNowCommand}" Classes="Flat" Padding="10,6" CornerRadius="8"
                            Foreground="#4CAF50" FontWeight="Medium">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <avalonia:MaterialIcon Kind="Play" Width="16" Height="16" />
                            <TextBlock Text="立即执行" FontSize="13" />
                        </StackPanel>
                    </Button>

                    <Border Width="1" Height="20" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            VerticalAlignment="Center" Margin="4,0" />

                    <Button Command="{Binding PauseCommand}" Classes="Flat" Padding="6" CornerRadius="6"
                            Foreground="#FF9800" ToolTip.Tip="暂停任务">
                        <avalonia:MaterialIcon Kind="Pause" Width="16" Height="16" />
                    </Button>
                    <Button Command="{Binding ResumeCommand}" Classes="Flat" Padding="6" CornerRadius="6"
                            Foreground="#2196F3" ToolTip.Tip="恢复任务">
                        <avalonia:MaterialIcon Kind="Replay" Width="16" Height="16" />
                    </Button>

                    <Border Width="1" Height="20" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            VerticalAlignment="Center" Margin="4,0" />

                    <Button Command="{Binding EditCommand}" Classes="Flat" Padding="6" CornerRadius="6"
                            ToolTip.Tip="编辑任务">
                        <avalonia:MaterialIcon Kind="Pencil" Width="16" Height="16" />
                    </Button>
                    <Button Command="{Binding DeleteCommand}" Classes="Flat" Padding="6" CornerRadius="6"
                            Foreground="#FF0000" ToolTip.Tip="删除任务">
                        <avalonia:MaterialIcon Kind="Delete" Width="16" Height="16" />
                    </Button>

                    <Border Width="1" Height="20" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            VerticalAlignment="Center" Margin="4,0" />

                    <Button Command="{Binding CopyCommand}" Classes="Flat" Padding="6" CornerRadius="6"
                            ToolTip.Tip="复制任务到剪贴板">
                        <avalonia:MaterialIcon Kind="ContentCopy" Width="16" Height="16" />
                    </Button>
                    <Button Command="{Binding ExportCommand}" Classes="Flat" Padding="6" CornerRadius="6"
                            ToolTip.Tip="导出任务为 JSON">
                        <avalonia:MaterialIcon Kind="Export" Width="16" Height="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Region 2: Basic Info -->
        <Border Grid.Row="1" Padding="24,16"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <controls:StatusBadge Text="{Binding CurrentTask.Group}" Status="Normal" />
                    <TextBlock FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center">
                        <Run Text="创建于 " />
                        <Run Text="{Binding CurrentTask.CreatedAt, StringFormat='{}{0:yyyy-MM-dd}'}" />
                        <Run Text=" · 最近编辑 " />
                        <Run Text="{Binding CurrentTask.UpdatedAt, StringFormat='{}{0:yyyy-MM-dd}'}" />
                    </TextBlock>
                </StackPanel>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                    <controls:SectionCard Title="任务配置" Grid.Column="0">
                        <StackPanel Spacing="6">
                            <controls:InfoRow Label="任务名称" Value="{Binding CurrentTask.Name}" />
                            <controls:InfoRow Label="分组" Value="{Binding CurrentTask.Group}" />
                            <controls:InfoRow Label="优先级" Value="{Binding CurrentTask.Priority}" />
                            <controls:InfoRow Label="触发器类型" Value="{Binding CurrentTask.FirstTrigger.Type}" />
                            <ItemsControl ItemsSource="{Binding CurrentTask.Triggers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:TriggerInfo">
                                        <controls:InfoRow Label="调度规则" Value="{Binding TriggerDisplay}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <controls:InfoRow Label="使用开机时间" Value="{Binding CurrentTask.UseBootTime}" />
                        </StackPanel>
                    </controls:SectionCard>

                    <controls:SectionCard Title="调度状态" Grid.Column="1">
                        <StackPanel Spacing="6">
                            <controls:InfoRow Label="上次执行"
                                              Value="{Binding Statistics.LastExecutionTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" />
                            <controls:InfoRow Label="累计执行" Value="{Binding Statistics.TotalExecutions}" />
                            <controls:InfoRow Label="成功率" Value="{Binding Statistics.SuccessRateDisplay}" />
                            <controls:InfoRow Label="平均耗时" Value="{Binding Statistics.AverageDurationDisplay}" />
                            <controls:InfoRow Label="连续失败" Value="{Binding Statistics.ConsecutiveFailures}" />
                        </StackPanel>
                    </controls:SectionCard>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Region 3: Command Script (elastic height with internal scroll) -->
        <Border Grid.Row="2" Padding="24,16"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1">
            <controls:SectionCard Title="命令详情"
                                  IsVisible="{Binding Command, Converter={x:Static ObjectConverters.IsNotNull}}">
                <DockPanel LastChildFill="True">
                    <!-- Top bar: type label + action buttons -->
                    <DockPanel DockPanel.Dock="Top" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                            <Button Command="{Binding CopyCommandCommand}" Classes="Flat" Padding="6,4" CornerRadius="6"
                                    ToolTip.Tip="复制命令">
                                <avalonia:MaterialIcon Kind="ContentCopy" Width="14" Height="14" />
                            </Button>
                            <Button Command="{Binding ExportCommandCommand}" Classes="Flat" Padding="6,4" CornerRadius="6"
                                    ToolTip.Tip="导出命令文件">
                                <avalonia:MaterialIcon Kind="Export" Width="14" Height="14" />
                            </Button>
                        </StackPanel>
                        <TextBlock Text="{Binding Command.Type}"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <!-- Command content: fills row, scrolls internally -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                CornerRadius="8" Padding="0,8"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding Command.Content}"
                                           FontFamily="Consolas,Courier New,monospace" FontSize="12"
                                           TextWrapping="NoWrap" />
                                <Border CornerRadius="4" Padding="6,2"
                                        Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                        HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Command.Type}"
                                               FontFamily="Consolas,Courier New,monospace" FontSize="10" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </DockPanel>
            </controls:SectionCard>
        </Border>

        <!-- Region 4: Execution Logs -->
        <Border Grid.Row="3" Padding="24,16"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1">
            <controls:SectionCard>
                <Grid RowDefinitions="Auto,Auto,Auto,*" HorizontalAlignment="Stretch">
                    <!-- Title bar: title left + view all button right edge -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                        <TextBlock Grid.Column="0" Text="最近执行记录" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="查看全部 →"
                                Command="{Binding ViewAllLogsCommand}"
                                Classes="link" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Column headers -->
                    <Grid Grid.Row="1" Margin="0,12,0,8" ColumnDefinitions="170,100,80,70,*"
                          ColumnSpacing="12" HorizontalAlignment="Stretch">
                        <TextBlock Grid.Column="0" Text="执行时间" FontSize="11" FontWeight="Medium"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock Grid.Column="1" Text="状态" FontSize="11" FontWeight="Medium"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock Grid.Column="2" Text="耗时" FontSize="11" FontWeight="Medium"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock Grid.Column="3" Text="退出码" FontSize="11" FontWeight="Medium"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock Grid.Column="4" Text="备注" FontSize="11" FontWeight="Medium"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </Grid>
                    <Border Grid.Row="2" Height="1"
                            Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />

                    <!-- Scrollable log rows -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Top">
                        <ItemsControl ItemsSource="{Binding RecentLogs}"
                                      HorizontalAlignment="Stretch">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ExecutionLog">
                                    <Border Padding="0,6"
                                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                            BorderThickness="0,0,0,1"
                                            HorizontalAlignment="Stretch">
                                        <Grid ColumnDefinitions="170,100,80,70,*"
                                              ColumnSpacing="12"
                                              HorizontalAlignment="Stretch">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding StartTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                       VerticalAlignment="Center" FontSize="12"
                                                       TextAlignment="Left"
                                                       FontFamily="Consolas,Courier New,monospace" />
                                            <controls:StatusBadge Grid.Column="1"
                                                Text="{Binding Status, Converter={StaticResource ExecutionStatusToDisplay}}"
                                                Status="{Binding Status, Converter={StaticResource ExecutionStatusToBadgeStatus}}"
                                                VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding DurationDisplay}"
                                                       VerticalAlignment="Center" FontSize="12"
                                                       TextAlignment="Left"
                                                       FontFamily="Consolas,Courier New,monospace" />
                                            <TextBlock Grid.Column="3" Text="{Binding ExitCode}"
                                                       VerticalAlignment="Center" FontSize="12"
                                                       TextAlignment="Left"
                                                       FontFamily="Consolas,Courier New,monospace" />
                                            <TextBlock Grid.Column="4" Text="{Binding Remark}"
                                                       VerticalAlignment="Center" FontSize="12"
                                                       TextAlignment="Left"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </controls:SectionCard>
        </Border>
    </Grid>
</UserControl>

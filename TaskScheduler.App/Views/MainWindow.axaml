<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TaskScheduler.App.ViewModels"
        xmlns:views="using:TaskScheduler.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:conv="using:TaskScheduler.App.Converters"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="TaskScheduler.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.ico"
        Title="TaskScheduler"
        MinWidth="1024" MinHeight="680"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen"
        SizeChanged="Window_OnSizeChanged">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="Auto,*">
        <!-- 侧边栏 -->
        <Border Grid.Column="0" x:Name="SidebarBorder"
                Width="260"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand 区域 -->
                <Border DockPanel.Dock="Top" Height="60" Padding="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                        <avalonia:MaterialIcon Kind="TimerCogOutline" Width="28" Height="28"
                                               Foreground="{DynamicResource SystemAccentColor}" />
                        <TextBlock Text="TaskScheduler" FontSize="16" FontWeight="Bold"
                                   x:Name="BrandText"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- 折叠按钮 -->
                <Button DockPanel.Dock="Bottom"
                        Height="40" Margin="8,0,8,8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding ToggleSidebarCommand}"
                        Classes="Flat">
                    <avalonia:MaterialIcon Kind="Menu" Width="20" Height="20" />
                </Button>

                <!-- 导航列表 -->
                <ListBox x:Name="NavListBox"
                         ItemsSource="{Binding NavItems}"
                         SelectedIndex="{Binding SelectedNavIndex}"
                         Margin="8,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:NavItem">
                            <Panel>
                                <!-- 普通导航项 -->
                                <Grid ColumnDefinitions="Auto,*" Margin="4,6"
                                      IsVisible="{Binding !IsSeparator}">
                                    <avalonia:MaterialIcon Grid.Column="0"
                                                           Kind="{Binding Icon}"
                                                           Width="20" Height="20"
                                                           VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               Margin="12,0,0,0" />
                                </Grid>
                                <!-- 分区标题 -->
                                <TextBlock Text="{Binding SectionHeader}"
                                           IsVisible="{Binding IsSection}"
                                           FontSize="12"
                                           Margin="4,12,0,4" />
                            </Panel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Column="1" RowDefinitions="60,*">
            <!-- 工具栏 -->
            <Border Grid.Row="0"
                    Height="60"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="20,0">
                <Grid ColumnDefinitions="*,Auto">
                    <!-- 标题（非设置页面） -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding PageTitle}"
                               FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !ShowSettingsToolbar}" />

                    <!-- 设置页面标题（左侧） -->
                    <TextBlock Grid.Column="0"
                               Text="全局设置"
                               FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               IsVisible="{Binding ShowSettingsToolbar}" />

                    <!-- 设置页面操作按钮（右侧） -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding ShowSettingsToolbar}"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    DataContext="{Binding SettingsViewModel}">
                            <Button Content="重置默认"
                                    Command="{Binding ResetDefaultsCommand}"
                                    Classes="Flat" Padding="12,6" />
                            <Border Width="1" Height="20"
                                    Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                    VerticalAlignment="Center" />
                            <Button Command="{Binding SaveAllCommand}"
                                    Padding="12,6" CornerRadius="8"
                                    Cursor="Hand"
                                    IsEnabled="{Binding IsSaving, Converter={x:Static conv:BoolConverters.Not}}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding SaveButtonText}" FontSize="12" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- 操作按钮（非编辑器页面） -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding !ShowEditorToolbar}"
                                VerticalAlignment="Center">
                        <Button Command="{Binding CreateNewTaskCommand}"
                                IsVisible="{Binding ShowCreateTaskButton}"
                                HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <avalonia:MaterialIcon Kind="Plus" Width="16" Height="16" />
                                <TextBlock Text="新建任务" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- 编辑器操作按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding ShowEditorToolbar}"
                                VerticalAlignment="Center">
                        <Button Content="取消"
                                Command="{Binding ActiveEditorViewModel.CancelCommand}"
                                Classes="Flat" />
                        <Border Width="1" Height="20"
                                Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                VerticalAlignment="Center" />
                        <Button Content="测试运行"
                                Command="{Binding ActiveEditorViewModel.TestRunCommand}"
                                IsEnabled="{Binding ActiveEditorViewModel.IsTesting, Converter={x:Static conv:BoolConverters.Not}}"
                                Classes="Flat" />
                        <Button Content="保存任务"
                                Command="{Binding ActiveEditorViewModel.SaveCommand}"
                                IsEnabled="{Binding ActiveEditorViewModel.IsSaving, Converter={x:Static conv:BoolConverters.Not}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 内容区域：通过 DataTemplate 自动切换 -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentPageViewModel}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Margin="0">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:DashboardViewModel">
                        <views:DashboardView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:TaskListViewModel">
                        <views:TaskListView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:TaskDetailViewModel">
                        <views:TaskDetailView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:TaskEditorViewModel">
                        <views:TaskEditorView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:ExecutionLogViewModel">
                        <views:ExecutionLogView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:SettingsViewModel">
                        <views:SettingsView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:AboutViewModel">
                        <views:AboutView />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Grid>
    </Grid>
</Window>

{
  "Instance": "TaskSchedulerApp",
  "Database": {
    "connectionString": "Data Source=TaskScheduler.db"
  },
  
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Debug"
    },
    "Enrich": [
      "FromLogContext",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:MM-dd HH:mm:ss.fff zzz} {Level:u3} {SourceContext} {CallerLineNumber} {ThreadId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 365,
          "flushToDiskInterval": "00:01:00",
          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "{Timestamp:MM-dd HH:mm:ss.fff zzz} {Level:u3} {SourceContext} {CallerLineNumber} {ThreadId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
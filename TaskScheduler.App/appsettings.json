{
  "Instance": "TaskSchedulerApp",
  "Quartz": {
    "scheduler": {
      "instanceName": "TaskScheduler",
      "instanceId": "AUTO"
    },
    "threadPool": {
      "type": "Quartz.Simpl.SimpleThreadPool, Quartz",
      "threadCount": 10,
      "threadPriority": "Normal"
    },
    "jobStore": {
      "type": "Quartz.Impl.AdoJobStore.JobStoreTX, Quartz",
      "driverDelegateType": "Quartz.Impl.AdoJobStore.SQLiteDelegate, Quartz",
      "useProperties": "true",
      "tablePrefix": "QRTZ_",
      "dataSource": "SQLiteDS"
    },
    "dataSource": {
      "SQLiteDS": {
        "connectionString": "Data Source=quartz.db",
        "provider": "SQLite"
      }
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Debug"
    },
    "Enrich": [
      "FromLogContext",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:MM-dd HH:mm:ss.fff zzz} {Level:u3} {SourceContext} {CallerLineNumber} {ThreadId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 365,
          "flushToDiskInterval": "00:01:00",
          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "{Timestamp:MM-dd HH:mm:ss.fff zzz} {Level:u3} {SourceContext} {CallerLineNumber} {ThreadId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}